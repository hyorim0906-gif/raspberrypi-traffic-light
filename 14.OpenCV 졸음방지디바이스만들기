import cv2                              # OpenCV 라이브러리 불러오기
from gpiozero import PWMOutputDevice    # PWM 방식 부저 제어 라이브러리
import time                             # 시간 관련 라이브러리

buzzerPin = PWMOutputDevice(16)         # GPIO 16번 핀에 부저 연결

def main():
    camera = cv2.VideoCapture(0)        # 웹캠 실행
    camera.set(3, 640)                  # 가로 해상도 설정
    camera.set(4, 480)                  # 세로 해상도 설정

    face_xml = '/usr/share/opencv4/haarcascades/haarcascade_frontalface_default.xml'   # 얼굴 검출 XML 파일 경로
    eye_xml = '/usr/share/opencv4/haarcascades/haarcascade_eye.xml'                     # 눈 검출 XML 파일 경로

    face_cascade = cv2.CascadeClassifier(face_xml)   # 얼굴 검출기 생성
    eye_cascade = cv2.CascadeClassifier(eye_xml)     # 눈 검출기 생성

    while(camera.isOpened()):            # 카메라 실행 중 반복
        _, image = camera.read()         # 현재 프레임 읽기
        gray = cv2.cvtColor(image, cv2.COLOR_BGR2GRAY)   # 흑백 이미지로 변환

        faces = face_cascade.detectMultiScale(
            gray,                        # 얼굴 검출 대상
            scaleFactor=1.1,            # 탐지 창 크기 10%씩 확대
            minNeighbors=5,             # 최소 5회 검출 시 얼굴 확정
            minSize=(100,100),          # 최소 얼굴 크기 설정
            flags=cv2.CASCADE_SCALE_IMAGE
        )

        print("faces detected Number: " + str(len(faces)))   # 검출된 얼굴 개수 출력

        if len(faces):                  # 얼굴이 검출되면
            for (x, y, w, h) in faces: # 얼굴 좌표 반복
                cv2.rectangle(image, (x,y), (x+w,y+h), (255,0,0), 2)   # 얼굴 영역 파란 사각형 표시

                face_gray = gray[y:y+h, x:x+w]    # 얼굴 영역 흑백 이미지 저장
                face_color = image[y:y+h, x:x+w]  # 얼굴 영역 컬러 이미지 저장

                eyes = eye_cascade.detectMultiScale(
                    face_gray,          # 얼굴 영역에서 눈 탐지
                    scaleFactor=1.1,   # 탐지 창 확대 비율
                    minNeighbors=5      # 최소 5회 탐지 시 확정
                )

                if len(eyes) <= 1:      # 눈이 1개 이하이면 졸음 상태
                    buzzerPin.value = 0.5   # 부저 작동
                else:                   # 눈이 2개 이상이면 정상 상태
                    buzzerPin.off()     # 부저 정지

                for (ex, ey, ew, eh) in eyes:   # 눈 좌표 반복
                    cv2.rectangle(face_color, (ex, ey), (ex+ew, ey+eh), (0,255,0), 2)   # 눈 영역 초록 사각형 표시

        cv2.imshow('result', image)     # 결과 화면 출력

        if cv2.waitKey(1) == ord('q'):  # q 키 입력 시 종료
            break

    cv2.destroyAllWindows()             # 모든 OpenCV 창 닫기
    buzzerPin.off()                     # 종료 시 부저 OFF

if __name__ == '__main__':              # 직접 실행 시
    main()                              # main 함수 실행
