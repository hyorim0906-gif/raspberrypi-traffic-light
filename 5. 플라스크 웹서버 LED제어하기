from flask import Flask                      # 웹서버 만들기 위한 Flask 라이브러리 불러오기
from gpiozero import LED                    # 라즈베리파이 GPIO 핀 제어용 LED 클래스 불러오기

app = Flask(__name__)                       # Flask 앱 생성 (서버 시작 준비)
red_led = LED(21)                           # GPIO 21번 핀에 연결된 LED 설정

@app.route('/')                             # 기본 주소(/)로 접속했을 때 실행되는 부분
def home():
    return render_template("index.html")    # index.html 파일을 화면에 보여줌

@app.route('/data', methods=['POST'])       # /data 주소로 POST 요청 들어오면 실행
def data():
    data = request.form['led']              # 웹페이지에서 버튼으로 보낸 'led' 값 가져오기

    if data == 'on':                        # 값이 'on'이면
        red_led.on()                        # LED 켜기

    elif data == 'off':                     # 값이 'off'이면
        red_led.off()                       # LED 끄기

    return home()                           # 실행 후 다시 메인 화면으로 돌아가기

if __name__ == "__main__":                  # 이 파일을 직접 실행할 때만 아래 코드 실행
    app.run(host="0.0.0.0", port=80)        # 모든 IP에서 접속 가능하게 80번 포트로 서버 실행
