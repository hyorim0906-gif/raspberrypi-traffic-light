import speech_recognition as sr # 음성 인식 라이브러리 불러오기
import requests # 인터넷에서 날씨 데이터 가져올 때 사용
import os # 음성 출력 명령 실행할 때 사용
import time # 시간 관련 기능 사용

API_KEY="7faaac12de74c5aa9969869355cecce2" # OpenWeatherMap API 키
url=f"https://api.openweathermap.org/data/2.5/weather?q=Seoul&appid={API_KEY}&units=metric" # 서울 날씨 정보 요청 주소

def speak(option, msg): # 음성 출력 함수
    os.system("espeak {}'{}'".format(option, msg)) # espeak로 음성 출력

try:
    while True: # 계속 반복 실행
        r=sr.Recognizer() # 음성 인식 객체 만들기

        with sr.Microphone() as source: # 마이크 사용
            print("Say something!") # 안내 문구 출력
            audio=r.listen(source) # 사용자 음성 듣기

        try:
            text=r.recognize_google(audio, language='ko-KR') # 음성을 한국어 텍스트로 변환
            print("You said: "+text) # 인식한 내용 출력

            if text in "날씨": # 날씨라는 말이 들어오면 실행
                print("날씨 음성을 인식하였습니다.") # 확인 문구 출력

                response=requests.get(url) # 날씨 데이터 요청
                data=response.json() # 받아온 데이터를 JSON으로 변환

                temp=data["main"]["temp"] # 현재 온도 가져오기
                humi=data["main"]["humidity"] # 현재 습도 가져오기

                msg='  기온은'+str(int(temp)) +'도습도는'+str(humi) +'퍼센트입니다' # 음성으로 읽을 문장 만들기

                option='-s 180 -p 50 -a 200 -v ko+f5' # 음성 속도, 높이, 음량 설정
                speak(option, msg) # 음성 출력

        except sr.UnknownValueError: # 음성을 인식 못했을 때
            print("Google Speech Recognition could not understand audio")

        except sr.RequestError as e: # 서버 요청 오류
            print("Could not request results from Google Speech Recognition service; {0}".format(e))

except KeyboardInterrupt: # Ctrl+C 누르면 종료
    pass
