import urllib.request # 인터넷에서 데이터 요청할 때 사용
import json # 받아온 JSON 데이터를 처리할 때 사용
import datetime # 현재 시간 확인용
import asyncio # 반복 실행을 위한 라이브러리
from telegram import Bot # 텔레그램 봇 사용

telegram_id = '8698516656' # 텔레그램 채팅 ID
my_token = '8738431614:AAGuKXLq_RzIKMua1uHIP7vD9hvuJ-i2MBY' # 봇 토큰
api_key = '7faaac12de74c5aa9969869355cecce2' # OpenWeatherMap API 키

bot = Bot(token=my_token) # 봇 객체 생성

ALERT_HOURS = [7, 10, 13, 16, 19, 22] # 정각 기준 알림 시간
ALERT_TIMES = ["08:30", "14:45"] # 추가 지정 알림 시간

def getWeather(): # 날씨 정보를 가져오는 함수
    url = f"https://api.openweathermap.org/data/2.5/forecast?q=Seoul&appid={api_key}&units=metric&lang=en&cnt=8" # 서울 날씨 요청 URL

    with urllib.request.urlopen(url) as r: # API 요청 보내기
        data = json.loads(r.read()) # 응답 데이터를 JSON으로 변환

    text = "" # 결과를 저장할 문자열

    for i in range(8): # 8개의 시간 데이터 반복
        item = data['list'][i] # 각 시간별 데이터 가져오기

        hour = str((int(item['dt_txt'][11:13]) + 9) % 24).zfill(2) # 시간 추출 후 한국 시간으로 변환
        temp = item['main']['temp'] # 기온 값
        humi = item['main']['humidity'] # 습도 값
        desc = item['weather'][0]['description'] # 날씨 상태

        text += f"({hour}h {temp}C {humi}% {desc})\n" # 문자열에 추가

    return text # 완성된 문자열 반환


async def main(): # 메인 실행 함수
    try:
        while True: # 계속 반복 실행
            now = datetime.datetime.now() # 현재 시간 가져오기
            hm = now.strftime('%H:%M') # 시:분 형태로 변환

            is_alert_hour = now.hour in ALERT_HOURS and now.minute == 0 and now.second == 0 # 정각 알림 조건
            is_alert_time = hm in ALERT_TIMES and now.second == 0 # 지정 시간 알림 조건

            if is_alert_hour or is_alert_time: # 조건이 맞으면 실행
                msg = getWeather() # 날씨 정보 가져오기
                print(msg) # 터미널에 출력
                await bot.send_message(chat_id=telegram_id, text=msg) # 텔레그램으로 전송

            await asyncio.sleep(1) # 1초마다 반복

    except KeyboardInterrupt: # Ctrl+C 입력 시 종료
        pass


asyncio.run(main()) # 프로그램 실행
